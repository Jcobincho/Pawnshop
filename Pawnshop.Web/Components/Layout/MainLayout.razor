@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Pawnshop.Application.UsersApplication.Commands.Logout
@using Pawnshop.Application.UsersApplication.Responses
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using Pawnshop.Web.Services.AuthenticationService

@using Pawnshop.Web.Themes
@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject AuthStateProviderService AuthStateProviderService
@inject ApiService ApiService
@inject ProtectedLocalStorage localStorage
@inject LanguageService Lang
@implements IDisposable

@rendermode InteractiveServer

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_pawnshopTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<style>
    /* GLOBAL PREMIUM STYLES */
    .mud-card {
        border: 1px solid rgba(197, 160, 89, 0.15) !important;
        background-color: var(--mud-palette-surface) !important;
    }

    .mud-button-outlined-primary {
        border: 1px solid rgba(197, 160, 89, 0.5) !important;
        background: rgba(197, 160, 89, 0.03);
    }

    .currency-font {
        font-family: 'JetBrains Mono', monospace !important;
        font-weight: 600 !important;
    }

    .uppercase-label {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
        opacity: 0.7;
    }

    .border-gold-glow {
        border: 1px solid rgba(197, 160, 89, 0.4) !important;
        box-shadow: 0 0 15px rgba(197, 160, 89, 0.1) !important;
    }
    
    .mud-appbar {
        border-bottom: 1px solid rgba(197, 160, 89, 0.1);
    }

    .mud-nav-link {
        font-family: 'Outfit', sans-serif !important;
        font-weight: 500 !important;
    }

    .bg-surface-alpha {
        background-color: var(--mud-palette-surface);
        opacity: 0.9;
        backdrop-filter: blur(4px);
        border: 1px solid var(--mud-palette-lines-default);
    }
</style>

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Dense="false">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-4"
                         Style="font-family: 'Outfit', sans-serif; font-weight: 700; letter-spacing: 0.5px;">
                    @Lang.AppTitle.ToUpper()
                </MudText>
                <MudSpacer />
                
                <MudButton Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Language" OnClick="@ToggleLang"
                           Class="mr-4">
                    @(Lang.IsPolish ? "PL" : "EN")
                </MudButton>

                <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit" OnClick="@ToggleDarkMode" />
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               OnClick="@ApiService.LogoutHandler" />
            </MudAppBar>

            <MudDrawer @bind-Open="@open" ClipMode="DrawerClipMode.Always" Elevation="0"
                       Variant="@DrawerVariant.Responsive" Style="border-right: 1px solid rgba(197, 160, 89, 0.1);">
                <NavMenu />
            </MudDrawer>

            <MudMainContent Class="pa-6 mt-16">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
        <div style="position: absolute; right: 24px; top: 24px; z-index: 1000;" class="d-flex gap-3 pa-2 rounded-lg bg-surface-alpha">
            <MudButton Color="Color.Primary" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Language" OnClick="@ToggleLang"
                       Style="font-family: 'Outfit', sans-serif; font-weight: 600;">
                @(Lang.IsPolish ? "PL" : "EN")
            </MudButton>
            <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Primary" OnClick="@ToggleDarkMode" />
        </div>
        @Body
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code
{
    private bool open = true;
    private bool _isDarkMode = false; 

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
    }

    private void ToggleDrawer() => open = !open;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void ToggleLang() => Lang.ToggleLanguage();

    public void Dispose()
    {
        Lang.OnLanguageChanged -= StateHasChanged;
    }

    private readonly PawnshopTheme _pawnshopTheme = new PawnshopTheme();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await ((AuthStateProviderService)AuthStateProvider).InitializeAuthenticationState();
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;

                if (!user.Identity.IsAuthenticated && NavigationManager.Uri != NavigationManager.BaseUri)
                {
                    NavigationManager.NavigateTo("/");
                }
            }
            catch (Exception)
            {
                NavigationManager.NavigateTo("/", true);
            }
        }
    }
}
