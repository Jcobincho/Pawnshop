@using Pawnshop.Application.UsersApplication.Commands.CreateUser
@using Pawnshop.Application.UsersApplication.Commands.EditUser
@using Pawnshop.Application.UsersApplication.Dto
@using Pawnshop.Application.UsersApplication.Responses
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor

@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject LanguageService Lang
@implements IDisposable

<DetailModalOverlay>
    <MudCard Class="w-50" Style="max-height: 85vh; overflow: auto; border-radius: 12px;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">
                    <b>@Lang.UserManagement - @(SelectedAction == UniversalCrudMenu.CrudAction.Add ? Lang.Add : (SelectedAction == UniversalCrudMenu.CrudAction.Update ? Lang.Update : Lang.Details))</b>
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                <MudText Typo="Typo.h6" Align="Align.Center">@Lang.ConfirmDelete</MudText>
                <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">@CurrentUser?.UserName</MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem md="12">
                        <MudTextField @bind-Value="@UserName" Label="@Lang.Username" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    <MudItem md="12">
                        <MudTextField @bind-Value="@Email" Label="@Lang.Email" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    @if (SelectedAction == UniversalCrudMenu.CrudAction.Add)
                    {
                        <MudItem md="6">
                            <MudTextField @bind-Value="@Password" Label="@Lang.Password" InputType="InputType.Password" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem md="6">
                            <MudTextField @bind-Value="@RepeatedPassword" Label="@Lang.T("Powtórz hasło", "Repeat password")" InputType="InputType.Password" Variant="Variant.Outlined" />
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudCardContent>

        <MudCardActions Class="d-flex justify-space-between px-4 pb-4">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnDetailCancel">@Lang.Cancel</MudButton>
            @if (SelectedAction != UniversalCrudMenu.CrudAction.View)
            {
                <MudButton Variant="Variant.Filled" Color="@(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Color.Error : Color.Primary)" OnClick="HandleCrudAction">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : Lang.Save)
                </MudButton>
            }
        </MudCardActions>
    </MudCard>
</DetailModalOverlay>

@code {
    [Parameter] public GetAllUsersDto CurrentUser { get; set; }
    [Parameter] public UniversalCrudMenu.CrudAction SelectedAction { get; set; }
    [Parameter] public EventCallback OnDetailCancel { get; set; }
    [Parameter] public EventCallback OnCrudCompleted { get; set; }

    private string UserName { get; set; }
    private string Email { get; set; }
    private string Password { get; set; }
    private string RepeatedPassword { get; set; }

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        if (CurrentUser != null)
        {
            UserName = CurrentUser.UserName;
            Email = CurrentUser.Email;
        }
    }

    private async Task HandleCrudAction()
    {
        try
        {
            if (SelectedAction == UniversalCrudMenu.CrudAction.Add)
            {
                await ApiService.PostAsync<CreateUserCommand, CreateUserResponse>("Users/add", new CreateUserCommand { UserName = UserName, Email = Email, Password = Password, RepeatedPassword = RepeatedPassword });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Update)
            {
                await ApiService.PutAsync<UpdateUserCommand, UpdateUserResponse>("Users/update", new UpdateUserCommand { UserId = CurrentUser.Id, UserName = UserName, Email = Email });
            }
            // Add Delete logic if needed

            Snackbar.Add(Lang.SuccessSave, Severity.Success);
            await OnCrudCompleted.InvokeAsync();
            await OnDetailCancel.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Lang.ErrorGeneric}: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
