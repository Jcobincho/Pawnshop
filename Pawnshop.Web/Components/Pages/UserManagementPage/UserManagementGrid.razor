@using Pawnshop.Application.UsersApplication.Dto
@using Pawnshop.Application.UsersApplication.Responses
@using Pawnshop.Web.Exceptions
@using Pawnshop.Web.Services.ApiService
@using Pawnshop.Web.Components.Common

@inject ApiService ApiService

<UniversalGrid TItem="GetAllUsersDto" 
               Title="Lista Użytkowników"
               Items="@(usersFromApi?.Users ?? new List<GetAllUsersDto>())"
               OnItemSelected="HandleUserSelected"
               OnActionTriggered="HandleActionTriggered">
    <GridColumns>
        <PropertyColumn Property="@((GetAllUsersDto x) => x.UserId)" Title="User id" Hidden="true" />
        <PropertyColumn Property="@((GetAllUsersDto x) => x.UserName)" Title="User name" />
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Email)" Title="Email" />
        
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Roles)" Title="Roles">
            <CellTemplate>
                @string.Join(", ", context.Item.Roles ?? new List<string>())
            </CellTemplate>
        </PropertyColumn>
        
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Employee.EmployeeId)" Title="Employee id" Hidden="true" />
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Employee.Name)" Title="Name" />
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Employee.SecondName)" Title="Second name" Hidden="true" />
        <PropertyColumn Property="@((GetAllUsersDto x) => x.Employee.Surname)" Title="Surname" />
    </GridColumns>
</UniversalGrid>

@code {
    [Parameter] public EventCallback<GetAllUsersDto> OnUserSelected { get; set; }
    [Parameter] public EventCallback<UniversalCrudMenu.CrudAction> OnActionTriggered { get; set; }

    List<string> apiExceptions = null;
    public GetAllUsersResponse usersFromApi = new GetAllUsersResponse();

    protected override async Task OnInitializedAsync()
    {
        await GetUsersFromApiAsync();
        await InvokeAsync(StateHasChanged);
    }

    public async Task ReloadDataAsync()
    {
        await GetUsersFromApiAsync();
    }

    private async Task GetUsersFromApiAsync()
    {
        try
        {
            usersFromApi = await ApiService.GetAsync<GetAllUsersResponse>("/Users/get");
        }
        catch (ApiException ex)
        {
            apiExceptions = ex.ErrorMessages;
        }
    }

    private async Task HandleUserSelected(GetAllUsersDto user)
    {
        await OnUserSelected.InvokeAsync(user);
    }

    private async Task HandleActionTriggered(UniversalCrudMenu.CrudAction action)
    {
        await OnActionTriggered.InvokeAsync(action);
    }
}