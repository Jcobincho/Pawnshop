@page "/User-management-page"
@using Pawnshop.Application.UsersApplication.Dto
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Services
@inject LanguageService Lang
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-4">@Lang.UserManagement</MudText>

<UniversalCrudMenu IsItemSelected="@(currentUser != null)" OnActionSelected="HandleCrudAction" />

<UserManagementGrid OnUserSelected="HandleUserSelected" @ref="userGrid" />

@if(showDetail)
{
    <UserManagementDetail OnDetailCancel="HandleDetailCanceled" CurrentUser="currentUser" SelectedAction="selectedAction" OnCrudCompleted="HandleCrudCompleted" />
}

@code {
    private GetAllUsersDto currentUser = null;
    private bool showDetail = false;
    private UniversalCrudMenu.CrudAction selectedAction;
    private UserManagementGrid userGrid;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;

    private void HandleCrudAction(UniversalCrudMenu.CrudAction action)
    {
        selectedAction = action;
        showDetail = true;
    }

    private void HandleUserSelected(GetAllUsersDto selectedUser) => currentUser = selectedUser;

    private void HandleDetailCanceled() 
    {
        showDetail = false;
        currentUser = null;
    }

    private async Task HandleCrudCompleted() => await userGrid.ReloadDataAsync();

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
