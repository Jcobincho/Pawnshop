@using Pawnshop.Application.WorkplacesApplication.Dto
@using Pawnshop.Application.WorkplacesApplication.Responses
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor
@inject ApiService ApiService
@inject LanguageService Lang
@implements IDisposable

<MudTable Items="_workplaces" Hover="true" Breakpoint="Breakpoint.Md" Loading="_loading" 
          OnRowClick="@( (TableRowClickEventArgs<WorkplaceDto> e) => OnRowClick(e.Item) )" 
          T="WorkplaceDto" RowClassFunc="@SelectedRowClassFunc" Elevation="0">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<WorkplaceDto, object>(x=>x.Country)">@Lang.Country</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<WorkplaceDto, object>(x=>x.City)">@Lang.City</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<WorkplaceDto, object>(x=>x.StreetAndBuildingNumber)">@Lang.Street</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Lang.Country">@context.Country</MudTd>
        <MudTd DataLabel="@Lang.City">
            <MudText Color="Color.Primary" Style="font-weight: 600;">@context.City</MudText>
        </MudTd>
        <MudTd DataLabel="@Lang.Street">
            <MudText Class="currency-font">@context.StreetAndBuildingNumber</MudText>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">@Lang.T("Brak lombardów do wyświetlenia.", "No workplaces to display.")</MudAlert>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter] public EventCallback<WorkplaceDto> OnWorkplaceSelected { get; set; }
    
    private List<WorkplaceDto> _workplaces = new();
    private bool _loading = true;
    private WorkplaceDto _selectedItem;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;

    protected override async Task OnInitializedAsync() => await ReloadDataAsync();

    public async Task ReloadDataAsync()
    {
        _loading = true;
        try
        {
            var response = await ApiService.GetAsync<GetAllWorkplacesResponse>("Workplaces/get", null);
            _workplaces = response?.AllWorkplacesList ?? new();
        }
        catch (Exception) { }
        finally { _loading = false; StateHasChanged(); }
    }

    private void OnRowClick(WorkplaceDto workplace)
    {
        _selectedItem = workplace;
        OnWorkplaceSelected.InvokeAsync(workplace);
    }

    private string SelectedRowClassFunc(WorkplaceDto element, int rowNumber) => 
        _selectedItem != null && _selectedItem.Id == element.Id ? "selected-row-premium" : string.Empty;

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}

<style>
    .selected-row-premium {
        background-color: rgba(197, 160, 89, 0.1) !important;
        border-left: 4px solid var(--mud-palette-primary) !important;
    }
    
    .mud-table-row:hover {
        background-color: rgba(197, 160, 89, 0.05) !important;
    }
</style>
