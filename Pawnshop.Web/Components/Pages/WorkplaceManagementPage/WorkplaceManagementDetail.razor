@using Pawnshop.Application.WorkplacesApplication.Commands.AddWorkplace
@using Pawnshop.Application.WorkplacesApplication.Commands.DeleteWorkplace
@using Pawnshop.Application.WorkplacesApplication.Commands.UpdateWorkplace
@using Pawnshop.Application.WorkplacesApplication.Dto
@using Pawnshop.Application.WorkplacesApplication.Responses
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor

@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject LanguageService Lang
@implements IDisposable

<DetailModalOverlay>
    <MudCard Class="w-50 border-gold-glow" Style="max-height: 90vh; overflow: auto; border-radius: 20px;">
        <MudCardHeader Class="pa-6" Style="border-bottom: 1px solid rgba(197, 160, 89, 0.1);">
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--mud-palette-primary); text-transform: uppercase;">
                    @Lang.WorkplaceManagement
                </MudText>
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Add ? Lang.Add : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.Update ? Lang.Update : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.AddCopy ? Lang.T("Kopiuj", "Copy") : Lang.Details))))
                </MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="OnDetailCancel" Color="Color.Default" />
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent Class="pa-8">
            @if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-6" Style="border-radius: 12px;">@Lang.ConfirmDelete</MudAlert>
                <div class="d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOff" Color="Color.Error" Size="Size.Large" Class="mb-4" />
                    <MudText Typo="Typo.h6" Align="Align.Center">@CurrentWorkplace?.City, @CurrentWorkplace?.StreetAndBuildingNumber</MudText>
                </div>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Country" Label="@Lang.Country" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Region" Label="@Lang.Region" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="@City" Label="@Lang.City" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="@Street" Label="@Lang.Street" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@ZipCode" Label="@Lang.ZipCode" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>

        <MudCardActions Class="pa-6 d-flex justify-space-between" Style="background-color: rgba(0,0,0,0.05);">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnDetailCancel"
                       Style="font-family: 'Outfit', sans-serif; font-weight: 500;">
                @Lang.Cancel
            </MudButton>
            @if (SelectedAction != UniversalCrudMenu.CrudAction.View)
            {
                <MudButton Variant="Variant.Filled" 
                           Color="@(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Color.Error : Color.Primary)" 
                           OnClick="HandleCrudAction"
                           Style="font-family: 'Outfit', sans-serif; font-weight: 600; min-width: 120px;">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : Lang.Save)
                </MudButton>
            }
        </MudCardActions>
    </MudCard>
</DetailModalOverlay>

@code {
    [Parameter] public WorkplaceDto CurrentWorkplace { get; set; }
    [Parameter] public UniversalCrudMenu.CrudAction SelectedAction { get; set; }
    [Parameter] public EventCallback OnDetailCancel { get; set; }
    [Parameter] public EventCallback OnCrudCompleted { get; set; }

    private string Country { get; set; }
    private string Region { get; set; }
    private string City { get; set; }
    private string Street { get; set; }
    private string ZipCode { get; set; }

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        if (CurrentWorkplace != null)
        {
            Country = CurrentWorkplace.Country;
            Region = CurrentWorkplace.Region;
            City = SelectedAction == UniversalCrudMenu.CrudAction.AddCopy ? CurrentWorkplace.City + " (Copy)" : CurrentWorkplace.City;
            Street = CurrentWorkplace.StreetAndBuildingNumber;
            ZipCode = CurrentWorkplace.ZipCode;
        }
    }

    private async Task HandleCrudAction()
    {
        try
        {
            if (SelectedAction == UniversalCrudMenu.CrudAction.Add || SelectedAction == UniversalCrudMenu.CrudAction.AddCopy)
            {
                await ApiService.PostAsync<AddWorkplaceCommand, AddWorkplaceResponse>("Workplaces/add", new AddWorkplaceCommand { Country = Country, Region = Region, City = City, StreetAndBuildingNumber = Street, ZipCode = ZipCode });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Update)
            {
                await ApiService.PutAsync<UpdateWorkplaceCommand, UpdateWorkplaceResponse>("Workplaces/update", new UpdateWorkplaceCommand { WorkplaceId = CurrentWorkplace.Id, Country = Country, Region = Region, City = City, StreetAndBuildingNumber = Street, ZipCode = ZipCode });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                await ApiService.DeleteAsync<DeleteWorkplaceCommand, DeleteWorkplaceResponse>("Workplaces/delete", new DeleteWorkplaceCommand { WorkplaceId = CurrentWorkplace.Id });
            }

            Snackbar.Add(Lang.T("Zapisano pomyślnie.", "Saved successfully."), Severity.Success);
            await OnCrudCompleted.InvokeAsync();
            await OnDetailCancel.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Lang.ErrorGeneric}: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
