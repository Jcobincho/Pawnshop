@using Pawnshop.Application.ClientsApplication.Commands.AddClient
@using Pawnshop.Application.ClientsApplication.Commands.DeleteClient
@using Pawnshop.Application.ClientsApplication.Commands.UpdateClient
@using Pawnshop.Application.ClientsApplication.Dto
@using Pawnshop.Application.ClientsApplication.Responses
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor

@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject LanguageService Lang
@implements IDisposable

<DetailModalOverlay>
    <MudCard Class="w-50" Style="max-height: 85vh; overflow: auto; border-radius: 12px;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">
                    <b>@Lang.ClientManagement - @(SelectedAction == UniversalCrudMenu.CrudAction.Add ? Lang.Add : (SelectedAction == UniversalCrudMenu.CrudAction.Update ? Lang.Update : Lang.Details))</b>
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                <MudText Typo="Typo.h6" Align="Align.Center">@Lang.ConfirmDelete</MudText>
                <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">@CurrentClient?.Name @CurrentClient?.Surname</MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem md="6">
                        <MudTextField @bind-Value="@Name" Label="@Lang.Name" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    <MudItem md="6">
                        <MudTextField @bind-Value="@Surname" Label="@Lang.Surname" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    <MudItem md="12">
                        <MudTextField @bind-Value="@Pesel" Label="@Lang.Pesel" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    <MudItem md="12">
                        <MudTextField @bind-Value="@Email" Label="@Lang.Email" Variant="Variant.Outlined" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>

        <MudCardActions Class="d-flex justify-space-between px-4 pb-4">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnDetailCancel">@Lang.Cancel</MudButton>
            @if (SelectedAction != UniversalCrudMenu.CrudAction.View)
            {
                <MudButton Variant="Variant.Filled" Color="@(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Color.Error : Color.Primary)" OnClick="HandleCrudAction">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : Lang.Save)
                </MudButton>
            }
        </MudCardActions>
    </MudCard>
</DetailModalOverlay>

@code {
    [Parameter] public ClientDto CurrentClient { get; set; }
    [Parameter] public UniversalCrudMenu.CrudAction SelectedAction { get; set; }
    [Parameter] public EventCallback OnDetailCancel { get; set; }
    [Parameter] public EventCallback OnCrudCompleted { get; set; }

    private string Name { get; set; }
    private string Surname { get; set; }
    private string Pesel { get; set; }
    private string Email { get; set; }

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        if (CurrentClient != null)
        {
            Name = CurrentClient.Name;
            Surname = CurrentClient.Surname;
            Pesel = CurrentClient.Pesel;
            Email = CurrentClient.Email;
        }
    }

    private async Task HandleCrudAction()
    {
        try
        {
            if (SelectedAction == UniversalCrudMenu.CrudAction.Add)
            {
                await ApiService.PostAsync<AddClientCommand, AddClientResponse>("Clients/add", new AddClientCommand { Name = Name, Surname = Surname, Pesel = Pesel, Email = Email, BirthDate = DateTime.Now, IdCardNumber = "TEMP" });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Update)
            {
                await ApiService.PutAsync<UpdateClientCommand, UpdateClientResponse>("Clients/update", new UpdateClientCommand { ClientId = CurrentClient.Id, Name = Name, Surname = Surname, Pesel = Pesel, Email = Email, BirthDate = DateTime.Now, IdCardNumber = "TEMP" });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                await ApiService.DeleteAsync<DeleteClientCommand, DeleteClientResponse>("Clients/delete", new DeleteClientCommand { ClientId = CurrentClient.Id });
            }

            Snackbar.Add(Lang.SuccessSave, Severity.Success);
            await OnCrudCompleted.InvokeAsync();
            await OnDetailCancel.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Lang.ErrorGeneric}: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
