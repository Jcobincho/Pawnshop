@using Pawnshop.Application.ClientsApplication.Commands.AddClient
@using Pawnshop.Application.ClientsApplication.Commands.DeleteClient
@using Pawnshop.Application.ClientsApplication.Commands.UpdateClient
@using Pawnshop.Application.ClientsApplication.Dto
@using Pawnshop.Application.ClientsApplication.Responses
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor

@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject LanguageService Lang
@implements IDisposable

<DetailModalOverlay>
    <MudCard Class="w-50 border-gold-glow" Style="max-height: 90vh; overflow: auto; border-radius: 20px;">
        <MudCardHeader Class="pa-6" Style="border-bottom: 1px solid rgba(197, 160, 89, 0.1);">
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--mud-palette-primary); text-transform: uppercase;">
                    @Lang.ClientManagement
                </MudText>
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Add ? Lang.Add : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.Update ? Lang.Update : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : 
                      (SelectedAction == UniversalCrudMenu.CrudAction.AddCopy ? Lang.T("Kopiuj", "Copy") : Lang.Details))))
                </MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="OnDetailCancel" Color="Color.Default" />
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent Class="pa-8">
            @if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-6" Style="border-radius: 12px;">@Lang.ConfirmDelete</MudAlert>
                <div class="d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Error" Size="Size.Large" Class="mb-4" />
                    <MudText Typo="Typo.h6" Align="Align.Center">@CurrentClient?.Name @CurrentClient?.Surname</MudText>
                    <MudText Typo="Typo.body2" Class="currency-font">@CurrentClient?.Pesel</MudText>
                </div>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Name" Label="@Lang.Name" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Surname" Label="@Lang.Surname" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Pesel" Label="@Lang.Pesel" Variant="Variant.Outlined" 
                                      Counter="11" MaxLength="11" Required="true"
                                      ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Class="currency-font" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="@Lang.T("Data Urodzenia", "Birth Date")" @bind-Date="@BirthDate" 
                                       Variant="Variant.Outlined" Required="true"
                                       ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@IdCardNumber" Label="@Lang.T("Nr Dowodu", "ID Card Number")" Variant="Variant.Outlined" 
                                      Required="true" ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@Email" Label="@Lang.Email" Variant="Variant.Outlined" 
                                      ReadOnly="@(SelectedAction == UniversalCrudMenu.CrudAction.View)" Style="font-family: 'Outfit', sans-serif;" />
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>

        <MudCardActions Class="pa-6 d-flex justify-space-between" Style="background-color: rgba(0,0,0,0.05);">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnDetailCancel"
                       Style="font-family: 'Outfit', sans-serif; font-weight: 500;">
                @Lang.Cancel
            </MudButton>
            @if (SelectedAction != UniversalCrudMenu.CrudAction.View)
            {
                <MudButton Variant="Variant.Filled" 
                           Color="@(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Color.Error : Color.Primary)" 
                           OnClick="HandleCrudAction"
                           Style="font-family: 'Outfit', sans-serif; font-weight: 600; min-width: 120px;">
                    @(SelectedAction == UniversalCrudMenu.CrudAction.Delete ? Lang.Delete : Lang.Save)
                </MudButton>
            }
        </MudCardActions>
    </MudCard>
</DetailModalOverlay>

@code {
    [Parameter] public ClientDto CurrentClient { get; set; }
    [Parameter] public UniversalCrudMenu.CrudAction SelectedAction { get; set; }
    [Parameter] public EventCallback OnDetailCancel { get; set; }
    [Parameter] public EventCallback OnCrudCompleted { get; set; }

    private string Name { get; set; }
    private string Surname { get; set; }
    private string Pesel { get; set; }
    private string Email { get; set; }
    private string IdCardNumber { get; set; }
    private DateTime? BirthDate { get; set; } = DateTime.Now.AddYears(-20);

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        if (CurrentClient != null)
        {
            Name = SelectedAction == UniversalCrudMenu.CrudAction.AddCopy ? CurrentClient.Name + " (Copy)" : CurrentClient.Name;
            Surname = CurrentClient.Surname;
            Pesel = CurrentClient.Pesel;
            Email = CurrentClient.Email;
            IdCardNumber = CurrentClient.IdCardNumber;
            BirthDate = CurrentClient.BirthDate;
        }
    }

    private async Task HandleCrudAction()
    {
        try
        {
            if (string.IsNullOrEmpty(Pesel) || Pesel.Length != 11)
            {
                Snackbar.Add(Lang.T("PESEL musi mieć 11 znaków.", "PESEL must have 11 characters."), Severity.Warning);
                return;
            }

            if (BirthDate == null || BirthDate > DateTime.Now.AddYears(-18))
            {
                Snackbar.Add(Lang.T("Klient musi być pełnoletni.", "Client must be at least 18 years old."), Severity.Warning);
                return;
            }

            if (SelectedAction == UniversalCrudMenu.CrudAction.Add || SelectedAction == UniversalCrudMenu.CrudAction.AddCopy)
            {
                await ApiService.PostAsync<AddClientCommand, AddClientResponse>("Clients/add", new AddClientCommand 
                { 
                    Name = Name, 
                    Surname = Surname, 
                    Pesel = Pesel, 
                    Email = Email, 
                    BirthDate = BirthDate.Value, 
                    IdCardNumber = IdCardNumber 
                });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Update)
            {
                await ApiService.PutAsync<UpdateClientCommand, UpdateClientResponse>("Clients/update", new UpdateClientCommand 
                { 
                    ClientId = CurrentClient.Id, 
                    Name = Name, 
                    Surname = Surname, 
                    Pesel = Pesel, 
                    Email = Email, 
                    BirthDate = BirthDate.Value, 
                    IdCardNumber = IdCardNumber 
                });
            }
            else if (SelectedAction == UniversalCrudMenu.CrudAction.Delete)
            {
                await ApiService.DeleteAsync<DeleteClientCommand, DeleteClientResponse>("Clients/delete", new DeleteClientCommand { ClientId = CurrentClient.Id });
            }

            Snackbar.Add(Lang.T("Zapisano pomyślnie.", "Saved successfully."), Severity.Success);
            await OnCrudCompleted.InvokeAsync();
            await OnDetailCancel.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{Lang.ErrorGeneric}: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
