@using Pawnshop.Application.ClientsApplication.Dto
@using Pawnshop.Application.ClientsApplication.Responses
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor
@inject ApiService ApiService
@inject LanguageService Lang
@implements IDisposable

<MudTable Items="_clients" Hover="true" Breakpoint="Breakpoint.Md" Loading="_loading" 
          OnRowClick="@( (TableRowClickEventArgs<ClientDto> e) => OnRowClick(e.Item) )" 
          T="ClientDto" RowClassFunc="@SelectedRowClassFunc" Elevation="0">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x=>x.Name)">@Lang.Name</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x=>x.Surname)">@Lang.Surname</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x=>x.Pesel)">@Lang.Pesel</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x=>x.Email)">@Lang.Email</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Lang.Name">@context.Name</MudTd>
        <MudTd DataLabel="@Lang.Surname">
            <MudText Color="Color.Primary" Style="font-weight: 600;">@context.Surname</MudText>
        </MudTd>
        <MudTd DataLabel="@Lang.Pesel">
            <MudText Class="currency-font">@context.Pesel</MudText>
        </MudTd>
        <MudTd DataLabel="@Lang.Email">@context.Email</MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">@Lang.T("Brak klientów do wyświetlenia.", "No clients to display.")</MudAlert>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter] public EventCallback<ClientDto> OnClientSelected { get; set; }
    
    private List<ClientDto> _clients = new();
    private bool _loading = true;
    private ClientDto _selectedItem;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;

    protected override async Task OnInitializedAsync() => await ReloadDataAsync();

    public async Task ReloadDataAsync()
    {
        _loading = true;
        try
        {
            var response = await ApiService.GetAsync<GetAllClientsResponse>("Clients/get", new { PaginationParameters = new { PageNumber = 1, PageSize = 100 } });
            _clients = response?.AllClientsList?.Data ?? new();
        }
        catch (Exception) { }
        finally { _loading = false; StateHasChanged(); }
    }

    private void OnRowClick(ClientDto client)
    {
        _selectedItem = client;
        OnClientSelected.InvokeAsync(client);
    }

    private string SelectedRowClassFunc(ClientDto element, int rowNumber) => 
        _selectedItem != null && _selectedItem.Id == element.Id ? "selected-row-premium" : string.Empty;

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}

<style>
    .selected-row-premium {
        background-color: rgba(197, 160, 89, 0.1) !important;
        border-left: 4px solid var(--mud-palette-primary) !important;
    }
    
    .mud-table-row:hover {
        background-color: rgba(197, 160, 89, 0.05) !important;
    }
</style>
