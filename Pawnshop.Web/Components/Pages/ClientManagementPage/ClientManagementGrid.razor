@using Pawnshop.Application.ClientsApplication.Dto
@using Pawnshop.Application.Common.Pagination
@inject Pawnshop.Web.Services.ApiService.ApiService ApiService

<MudDataGrid T="ClientDto"
             ServerData="ServerReload"
             @ref="_grid"
             RowClick="OnRowClicked"
             RowClassFunc="@((item, idx) => item == selectedEmployee ? "selected-row" : string.Empty)"
             FilterMode="DataGridFilterMode.Simple"
             Striped="true">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" />
        <PropertyColumn Property="x => x.Surname" Title="Surname" />
        <PropertyColumn Property="x => x.Pesel" Title="PESEL" />
        <PropertyColumn Property="x => x.IdCardNumber" Title="ID Card" />
    </Columns>
    <PagerContent>
        <MudDataGridPager T="ClientDto" />
    </PagerContent>
</MudDataGrid>

@code {
    [Parameter] public EventCallback<ClientDto> OnClientSelected { get; set; }
    
    private MudDataGrid<ClientDto> _grid;
    private ClientDto selectedEmployee;

    
    private async Task<GridData<ClientDto>> ServerReload(GridState<ClientDto> state)
    {
        try
        {
            var page = state.Page + 1;
            var pageSize = state.PageSize;

            var url = $"/Clients/get?pageNumber={page}&pageSize={pageSize}";
            var response = await ApiService.GetAsync<PagedResult<ClientDto>>(url);

            return new GridData<ClientDto>
            {
                TotalItems = response.TotalCount,
                Items = response.Data
            };
        }
        catch (Exception ex)
        {
            return new GridData<ClientDto> { Items = new List<ClientDto>(), TotalItems = 0 };
        }
    }

    public async Task ReloadDataAsync()
    {
        await _grid.ReloadServerData();
    }

    private async Task OnRowClicked(DataGridRowClickEventArgs<ClientDto> row)
    {
        selectedEmployee = row.Item;
        await OnClientSelected.InvokeAsync(selectedEmployee);
    }
}