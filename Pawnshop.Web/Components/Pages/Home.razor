@page "/Home"
@using Pawnshop.Application.UsersApplication.Commands.Logout
@using Pawnshop.Web.Exceptions
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@inject LanguageService Lang
@inject ApiService apiService
@implements IDisposable

<MudText Typo="Typo.h3">@Lang.Home</MudText>

<MudPaper Class="pa-8 mt-4">
    <MudText Typo="Typo.h5">@Lang.Welcome</MudText>
    <MudText Typo="Typo.body1" Class="mt-2">@Lang.T("Zarządzaj swoim lombardem efektywnie.", "Manage your pawnshop effectively.")</MudText>
</MudPaper>

@code {
    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
