@page "/Employee-management-page"

@using Pawnshop.Application.EmployeesApplication.Dto
@using Pawnshop.Web.Components.Common

<EmployeeManagementGrid OnEmployeeSelected="HandleEmployeeSelected" 
                      OnActionTriggered="HandleCrudAction" 
                      IsLookupMode="@IsLookupMode" 
                      OnEmployeePicked="HandleItemPicked"
                      @ref="employeeGrid" />

@if(showDetail)
{
    <EmployeeManagementDetail OnDetailCancel="HandleDetailCanceled" 
                              CurrentEmployee="currentEmployee" 
                              SelectedAction="selectedAction" 
                              OnCrudCompleted="HandleCrudCompleted" />
}

@code {
    [Parameter] public bool IsLookupMode { get; set; } = false;
    [Parameter] public EventCallback<EmployeeDto> OnEmployeePicked { get; set; }

    private EmployeeDto currentEmployee = null;
    private bool showDetail = false;
    private UniversalCrudMenu.CrudAction selectedAction;
    private EmployeeManagementGrid employeeGrid;

    private void HandleCrudAction(UniversalCrudMenu.CrudAction action)
    {
        selectedAction = action;
        
        if (action == UniversalCrudMenu.CrudAction.Add)
        {
            currentEmployee = new EmployeeDto
            {
                Name = string.Empty,
                SecondName = string.Empty,
                Surname = string.Empty,
                BirthDate = DateTime.Today
            };
        }

        showDetail = true;
    }

    private void HandleEmployeeSelected(EmployeeDto selectedEmployee) => currentEmployee = selectedEmployee;

    private void HandleDetailCanceled() => showDetail = false;

    private async Task HandleCrudCompleted() => await employeeGrid.ReloadDataAsync();
    
    private async Task HandleItemPicked(EmployeeDto employee)
    {
        if (OnEmployeePicked.HasDelegate)
        {
            await OnEmployeePicked.InvokeAsync(employee);
        }
    }
}