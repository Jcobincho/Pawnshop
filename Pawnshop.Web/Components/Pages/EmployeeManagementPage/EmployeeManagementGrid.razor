@using Pawnshop.Application.EmployeesApplication.Dto
@using Pawnshop.Application.EmployeesApplication.Responses
@using Pawnshop.Web.Exceptions
@using Pawnshop.Web.Services.ApiService
@using Pawnshop.Web.Components.Common

@inject ApiService ApiService

<UniversalGrid TItem="EmployeeDto" 
               Title="Lista Pracowników"
               Items="@(employeesFromApi?.AllEmployeesList ?? new List<EmployeeDto>())"
               OnItemSelected="HandleEmployeeSelected"
               OnActionTriggered="HandleActionTriggered">
    <GridColumns>
        <PropertyColumn Property="@((EmployeeDto x) => x.EmployeeId)" Title="Employee id" Hidden="true" />
        <PropertyColumn Property="@((EmployeeDto x) => x.Name)" Title="Name" />
        <PropertyColumn Property="@((EmployeeDto x) => x.SecondName)" Title="Second name" Hidden="true" />
        <PropertyColumn Property="@((EmployeeDto x) => x.Surname)" Title="Surname" />
        <PropertyColumn Property="@((EmployeeDto x) => x.BirthDate)" Title="Birth date" Format="dd.MM.yyyy" />
    </GridColumns>
</UniversalGrid>

@code {
    [Parameter] public EventCallback<EmployeeDto> OnEmployeeSelected { get; set; }
    [Parameter] public EventCallback<UniversalCrudMenu.CrudAction> OnActionTriggered { get; set; }

    public GetAllEmployeesResponse employeesFromApi = null;
    List<string> apiExceptions = null;

    protected override async Task OnInitializedAsync()
    {
        await GetEmployeeFromApiAsync();
    }

    public async Task ReloadDataAsync()
    {
        await GetEmployeeFromApiAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task GetEmployeeFromApiAsync()
    {
        try
        {
            employeesFromApi = await ApiService.GetAsync<GetAllEmployeesResponse>("/Employees/get");
        }
        catch (ApiException ex)
        {
            apiExceptions = ex.ErrorMessages;
        }
    }

    private async Task HandleEmployeeSelected(EmployeeDto employee)
    {
        await OnEmployeeSelected.InvokeAsync(employee);
    }

    private async Task HandleActionTriggered(UniversalCrudMenu.CrudAction action)
    {
        await OnActionTriggered.InvokeAsync(action);
    }
}