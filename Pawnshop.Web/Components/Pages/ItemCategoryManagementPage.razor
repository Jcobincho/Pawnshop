@page "/Item-category-management-page"
@using Pawnshop.Application.ItemCategoriesApplication.Dto
@using Pawnshop.Application.ItemCategoriesApplication.Responses
@using Pawnshop.Web.Components.Common
@using Pawnshop.Web.Components.Pages.TradingManagementPage
@using Pawnshop.Web.Services
@using Pawnshop.Web.Services.ApiService
@using MudBlazor
@inject ApiService ApiService
@inject ISnackbar _snackbar
@inject LanguageService Lang
@implements IDisposable

<div class="d-flex align-center mb-6">
    <MudText Typo="Typo.h4" Style="font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--mud-palette-primary); text-transform: uppercase; letter-spacing: 1px;">
        @Lang.Categories
    </MudText>
</div>

<MudPaper Class="pa-4" Elevation="4" Style="border-radius: 16px;">
    <UniversalGrid TItem="ItemCategoryDto" 
                   Title="@Lang.Categories"
                   Items="_categories"
                   OnItemSelected="HandleCategorySelected"
                   OnActionTriggered="HandleCrudAction">
        <GridColumns>
            <PropertyColumn T="ItemCategoryDto" TProperty="string" Property="x => x.Name" Title="@Lang.Name" />
            <PropertyColumn T="ItemCategoryDto" TProperty="string" Property="x => x.Description" Title="@Lang.Description" />
        </GridColumns>
    </UniversalGrid>
</MudPaper>

@if (_showDetail)
{
    <ItemCategoryDetail CurrentCategory="_selectedCategory"
                        SelectedAction="_selectedAction"
                        OnDetailCancel="() => _showDetail = false"
                        OnCrudCompleted="LoadCategories" />
}

@code
{
    private List<ItemCategoryDto> _categories = new();
    private ItemCategoryDto _selectedCategory = null;
    private bool _showDetail = false;
    private UniversalCrudMenu.CrudAction _selectedAction;

    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;

    protected override async Task OnInitializedAsync() => await LoadCategories();

    private async Task LoadCategories()
    {
        try
        {
            var response = await ApiService.GetAsync<GetAllItemCategoriesResponse>("ItemCategories/get", null);
            _categories = response?.AllItemCategoriesList ?? new();
        }
        catch (Exception) { }
    }

    private void HandleCategorySelected(ItemCategoryDto category) => _selectedCategory = category;

    private void HandleCrudAction(UniversalCrudMenu.CrudAction action)
    {
        _selectedAction = action;
        if (action == UniversalCrudMenu.CrudAction.Add)
        {
            _selectedCategory = null;
        }
        _showDetail = true;
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
